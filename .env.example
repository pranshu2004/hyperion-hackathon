# .env.example
# Copy to .env and fill in your own values. Or leave unset — the app
# degrades gracefully and runs the full deterministic RCA pipeline
# without any LLM configured (narrative/fix_suggestion will be empty).

HYPERION_LLM_BASE_URL=https://<your-resource>.services.ai.azure.com/openai/v1/
HYPERION_LLM_API_KEY=your_api_key_here
HYPERION_LLM_MODEL=gpt-5-mini
